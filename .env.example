# ServiceNow Instance
SN_INSTANCE=your_instance
SN_HOST=your_instance.service-now.com
SN_USER=admin
SN_PASSWORD=your_password

# ServiceNow App (optional, will be auto-resolved if not set)
SN_APP_SYS_ID=your_forecast_app_sys_id

# MID Server User (if used for ZCC)
MID_INSTANCE_USERNAME=mid.server
MID_INSTANCE_PASSWORD=your_password

# Metadata Collector
SN_METADATA_COLLECTOR_SYSID=your_collector_sys_id

# Postgres / Neon (if using ZCC Postgres)
NEON_API_KEY=your_neon_api_key
NEON_ORG_ID=your_org_id
NEON_PROJECT_ID=your_project_id
NEON_HOST=your_neon_host
NEON_PORT=5432
NEON_DB=neondb
NEON_USER=neondb_owner
NEON_PASSWORD=your_neon_password

# ServiceNow Catalog sys_ids (set after sn_govern.py has run once)
SN_RISK_DOMAIN_SYS_ID=your_risk_domain_sys_id
SN_FIN_DOMAIN_SYS_ID=your_fin_domain_sys_id

# Alternative instance (optional)
SN_INSTANCE_ALT=your_alt_instance
SN_USER_ALT=admin
SN_PASSWORD_ALT=your_alt_password
